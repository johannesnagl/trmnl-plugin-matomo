{% assign date_range = trmnl.plugin_settings.custom_fields_values.date_range %}
{% assign metrics = trmnl.plugin_settings.custom_fields_values.metrics %}
{% assign site_id = trmnl.plugin_settings.custom_fields_values.site_id %}
{% assign number_delim = trmnl.plugin_settings.custom_fields_values.number_format | default: ',' %}

{% assign visits_summary = data[0] %}
{% assign actions = data[1] %}
{% assign top_pages = data[2] %}
{% assign top_referrers = data[3] %}
{% assign top_countries = data[4] %}
{% assign site_info = data[5] %}

{% case date_range %}
  {% when 'period%3Dday%26date%3Dtoday' %}{% assign date_label = 'Today' %}
  {% when 'period%3Dday%26date%3Dyesterday' %}{% assign date_label = 'Yesterday' %}
  {% when 'period%3Drange%26date%3Dprevious7' %}{% assign date_label = 'Last 7 days' %}
  {% when 'period%3Drange%26date%3Dprevious30' %}{% assign date_label = 'Last 30 days' %}
  {% else %}{% assign date_label = date_range %}
{% endcase %}

{% if site_info.main_url %}
  {% assign url_no_proto = site_info.main_url | split: '://' | last %}
  {% assign host_only = url_no_proto | split: '/' | first %}
  {% assign site_label = host_only | replace: 'www.', '' %}
{% elsif site_info.name %}
  {% assign site_label = site_info.name %}
{% else %}
  {% assign site_label = 'site ' | append: site_id %}
{% endif %}

{% assign has_lists = false %}
{% if metrics contains 'top_pages' or metrics contains 'top_referrers' or metrics contains 'top_countries' %}
  {% assign has_lists = true %}
{% endif %}

{% if has_lists %}
  {% assign kpi_size = 'value--large' %}
{% else %}
  {% assign kpi_size = 'value--xxlarge' %}
{% endif %}

<div class="layout layout--col gap--large">

  <div class="columns">

    {% if metrics contains 'visits' %}
    <div class="column">
      <div class="title">Visits</div>
      <div class="value {{ kpi_size }}" data-value-fit="true">{{ visits_summary.nb_visits | number_with_delimiter: number_delim }}</div>
      <div class="label text--gray-45">{% if visits_summary.nb_uniq_visitors %}{{ visits_summary.nb_uniq_visitors | number_with_delimiter: number_delim }} unique · {% endif %}{{ visits_summary.bounce_rate }} bounce</div>
    </div>
    {% endif %}

    {% if metrics contains 'pageviews' %}
    <div class="column">
      <div class="title">Pageviews</div>
      <div class="value {{ kpi_size }}" data-value-fit="true">{{ actions.nb_pageviews | number_with_delimiter: number_delim }}</div>
      <div class="label text--gray-45">{{ actions.nb_uniq_pageviews | number_with_delimiter: number_delim }} unique pageviews</div>
    </div>
    {% endif %}

  </div>

  {% if has_lists %}
  <div class="columns">

    {% if metrics contains 'top_pages' %}
    <div class="column">
      <div class="title label--underline">Top pages</div>
      <table class="table table--base" style="width: 100%">
        <tbody>
          {% for row in top_pages limit:5 %}
          <tr>
            <td style="width: 70%"><span class="value value--xsmall" data-value-fit="true">{{ '/' | append: row.label | replace: '//', '/' | truncate: 24 }}</span></td>
            <td class="text--right" style="width: 30%"><span class="value value--xsmall" data-value-fit="true">{{ row.nb_hits | number_with_delimiter: number_delim }}</span></td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
    {% endif %}

    {% if metrics contains 'top_referrers' %}
    <div class="column">
      <div class="title label--underline">Top referrers</div>
      <table class="table table--base" style="width: 100%">
        <tbody>
          {% for row in top_referrers limit:5 %}
          <tr>
            <td style="width: 70%"><span class="value value--xsmall" data-value-fit="true">{{ row.label | truncate: 24 }}</span></td>
            <td class="text--right" style="width: 30%"><span class="value value--xsmall" data-value-fit="true">{{ row.nb_visits | number_with_delimiter: number_delim }}</span></td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
    {% endif %}

    {% if metrics contains 'top_countries' %}
    <div class="column">
      <div class="title label--underline">Top countries</div>
      <table class="table table--base" style="width: 100%">
        <tbody>
          {% for row in top_countries limit:5 %}
          <tr>
            <td style="width: 70%"><span class="value value--xsmall" data-value-fit="true">{{ row.label | truncate: 24 }}</span></td>
            <td class="text--right" style="width: 30%"><span class="value value--xsmall" data-value-fit="true">{{ row.nb_visits | number_with_delimiter: number_delim }}</span></td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
    {% endif %}

  </div>
  {% endif %}

</div>

<div class="title_bar">
  <img class="image" src="https://usetrmnl.com/images/plugins/trmnl--render.svg" />
  <span class="title">Matomo</span>
  <span class="instance">{{ date_label }} · {{ site_label }}</span>
</div>
