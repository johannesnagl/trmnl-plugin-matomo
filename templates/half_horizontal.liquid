{% assign date_range = trmnl.plugin_settings.custom_fields_values.date_range %}
{% assign metrics = trmnl.plugin_settings.custom_fields_values.metrics %}
{% assign site_id = trmnl.plugin_settings.custom_fields_values.site_id %}
{% assign number_delim = trmnl.plugin_settings.custom_fields_values.number_format | default: ',' %}

{% assign visits_summary = data[0] %}
{% assign actions = data[1] %}
{% assign top_pages = data[2] %}
{% assign top_referrers = data[3] %}
{% assign top_countries = data[4] %}
{% assign site_info = data[5] %}

{% case date_range %}
  {% when 'period%3Dday%26date%3Dtoday' %}{% assign date_label = 'Today' %}
  {% when 'period%3Dday%26date%3Dyesterday' %}{% assign date_label = 'Yesterday' %}
  {% when 'period%3Drange%26date%3Dprevious7' %}{% assign date_label = 'Last 7 days' %}
  {% when 'period%3Drange%26date%3Dprevious30' %}{% assign date_label = 'Last 30 days' %}
  {% else %}{% assign date_label = date_range %}
{% endcase %}

{% if site_info.main_url %}
  {% assign url_no_proto = site_info.main_url | split: '://' | last %}
  {% assign host_only = url_no_proto | split: '/' | first %}
  {% assign site_label = host_only | replace: 'www.', '' %}
{% elsif site_info.name %}
  {% assign site_label = site_info.name %}
{% else %}
  {% assign site_label = 'site ' | append: site_id %}
{% endif %}

<div class="layout">
  <div class="columns">

    {% if metrics contains 'visits' %}
    <div class="column">
      <div class="title">Visits</div>
      <div class="value value--large" data-value-fit="true">{{ visits_summary.nb_visits | number_with_delimiter: number_delim }}</div>
      <div class="label text--gray-45">{% if visits_summary.nb_uniq_visitors %}{{ visits_summary.nb_uniq_visitors | number_with_delimiter: number_delim }} unique{% else %}{{ visits_summary.bounce_rate }} bounce{% endif %}</div>
    </div>
    {% endif %}

    {% if metrics contains 'pageviews' %}
    <div class="column">
      <div class="title">Pageviews</div>
      <div class="value value--large" data-value-fit="true">{{ actions.nb_pageviews | number_with_delimiter: number_delim }}</div>
      <div class="label text--gray-45">{{ actions.nb_uniq_pageviews | number_with_delimiter: number_delim }} unique</div>
    </div>
    {% endif %}

    {% if metrics contains 'top_pages' %}
    <div class="column">
      <div class="title">Top page</div>
      <div class="value value--xsmall" data-value-fit="true">{{ '/' | append: top_pages[0].label | replace: '//', '/' | truncate: 22 }}</div>
      <div class="value value--small" data-value-fit="true">{{ top_pages[0].nb_hits | number_with_delimiter: number_delim }}</div>
    </div>
    {% endif %}

    {% if metrics contains 'top_referrers' %}
    <div class="column">
      <div class="title">Top referrer</div>
      <div class="value value--xsmall" data-value-fit="true">{{ top_referrers[0].label | truncate: 22 }}</div>
      <div class="value value--small" data-value-fit="true">{{ top_referrers[0].nb_visits | number_with_delimiter: number_delim }}</div>
    </div>
    {% endif %}

    {% if metrics contains 'top_countries' %}
    <div class="column">
      <div class="title">Top country</div>
      <div class="value value--xsmall" data-value-fit="true">{{ top_countries[0].label | truncate: 22 }}</div>
      <div class="value value--small" data-value-fit="true">{{ top_countries[0].nb_visits | number_with_delimiter: number_delim }}</div>
    </div>
    {% endif %}

  </div>
</div>

<div class="title_bar">
  <span class="title">Matomo</span>
  <span class="instance">{{ date_label }} · {{ site_label }}</span>
</div>
