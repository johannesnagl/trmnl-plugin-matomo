{% assign date_range = trmnl.plugin_settings.custom_fields_values.date_range %}
{% assign metrics = trmnl.plugin_settings.custom_fields_values.metrics %}
{% assign site_id = trmnl.plugin_settings.custom_fields_values.site_id %}

{% assign visits_summary = data[0] %}
{% assign actions = data[1] %}
{% assign top_pages = data[2] %}
{% assign top_referrers = data[3] %}
{% assign top_countries = data[4] %}

{% case date_range %}
  {% when 'period%3Dday%26date%3Dtoday' %}{% assign date_label = 'Today' %}
  {% when 'period%3Dday%26date%3Dyesterday' %}{% assign date_label = 'Yesterday' %}
  {% when 'period%3Drange%26date%3Dprevious7' %}{% assign date_label = 'Last 7 days' %}
  {% when 'period%3Drange%26date%3Dprevious30' %}{% assign date_label = 'Last 30 days' %}
  {% else %}{% assign date_label = date_range %}
{% endcase %}

<div class="layout">
  <div class="columns">

    {% if metrics contains 'visits' %}
    <div class="column">
      <span class="label">Visits</span>
      <span class="value value--large">{{ visits_summary.nb_visits }}</span>
      <span class="label label--small">{{ visits_summary.nb_uniq_visitors }} unique</span>
    </div>
    {% endif %}

    {% if metrics contains 'pageviews' %}
    <div class="column">
      <span class="label">Pageviews</span>
      <span class="value value--large">{{ actions.nb_pageviews }}</span>
      <span class="label label--small">{{ actions.nb_uniq_pageviews }} unique</span>
    </div>
    {% endif %}

    {% if metrics contains 'top_pages' %}
    <div class="column">
      <span class="label">Top page</span>
      <span class="title title--small">{{ top_pages[0].label | truncate: 22 }}</span>
      <span class="value value--medium">{{ top_pages[0].nb_hits }}</span>
    </div>
    {% endif %}

    {% if metrics contains 'top_referrers' %}
    <div class="column">
      <span class="label">Top referrer</span>
      <span class="title title--small">{{ top_referrers[0].label | truncate: 22 }}</span>
      <span class="value value--medium">{{ top_referrers[0].nb_visits }}</span>
    </div>
    {% endif %}

    {% if metrics contains 'top_countries' %}
    <div class="column">
      <span class="label">Top country</span>
      <span class="title title--small">{{ top_countries[0].label | truncate: 22 }}</span>
      <span class="value value--medium">{{ top_countries[0].nb_visits }}</span>
    </div>
    {% endif %}

  </div>
</div>

<div class="title_bar">
  <span class="title">Matomo</span>
  <span class="instance">{{ date_label }}</span>
</div>
