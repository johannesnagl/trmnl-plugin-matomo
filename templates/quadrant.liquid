{% comment %} Quadrant is tiny (400x240) — show only the first selected metric's headline number. {% endcomment %}
{% assign date_range = trmnl.plugin_settings.custom_fields_values.date_range %}
{% assign metrics = trmnl.plugin_settings.custom_fields_values.metrics %}
{% assign site_id = trmnl.plugin_settings.custom_fields_values.site_id %}
{% assign number_delim = trmnl.plugin_settings.custom_fields_values.number_format | default: ',' %}
{% if number_delim == 'null' %}{% assign number_delim = '' %}{% endif %}

{% assign visits_summary = data[0] %}
{% assign actions = data[1] %}
{% assign top_pages = data[2] %}
{% assign top_referrers = data[3] %}
{% assign top_countries = data[4] %}
{% assign site_info = data[5] %}

{% case date_range %}
  {% when 'period%3Dday%26date%3Dtoday' %}{% assign date_label = 'Today' %}
  {% when 'period%3Dday%26date%3Dyesterday' %}{% assign date_label = 'Yesterday' %}
  {% when 'period%3Drange%26date%3Dprevious7' %}{% assign date_label = 'Last 7 days' %}
  {% when 'period%3Drange%26date%3Dprevious30' %}{% assign date_label = 'Last 30 days' %}
  {% else %}{% assign date_label = date_range %}
{% endcase %}

{% if site_info.main_url %}
  {% assign url_no_proto = site_info.main_url | split: '://' | last %}
  {% assign host_only = url_no_proto | split: '/' | first %}
  {% assign site_label = host_only | replace: 'www.', '' %}
{% elsif site_info.name %}
  {% assign site_label = site_info.name %}
{% else %}
  {% assign site_label = 'site ' | append: site_id %}
{% endif %}

<div class="layout layout--col layout--center">

  {% if metrics contains 'visits' %}
    <div class="title lg:title--xlarge">Visits</div>
    <div class="value value--large lg:value--xxlarge" data-value-fit="true">{{ visits_summary.nb_visits | number_with_delimiter: number_delim }}</div>
    <div class="label lg:label--large text--gray-45">{{ visits_summary.nb_uniq_visitors | number_with_delimiter: number_delim }} unique</div>
  {% elsif metrics contains 'pageviews' %}
    <div class="title lg:title--xlarge">Pageviews</div>
    <div class="value value--large lg:value--xxlarge" data-value-fit="true">{{ actions.nb_pageviews | number_with_delimiter: number_delim }}</div>
    <div class="label lg:label--large text--gray-45">{{ actions.nb_uniq_pageviews | number_with_delimiter: number_delim }} unique</div>
  {% elsif metrics contains 'top_pages' %}
    <div class="title lg:title--xlarge">Top page</div>
    <div class="label lg:label--large">{{ '/' | append: top_pages[0].label | replace: '//', '/' | truncate: 24 }}</div>
    <div class="value value--large lg:value--xxlarge" data-value-fit="true">{{ top_pages[0].nb_hits | number_with_delimiter: number_delim }}</div>
  {% elsif metrics contains 'top_referrers' %}
    <div class="title lg:title--xlarge">Top referrer</div>
    <div class="label lg:label--large">{{ top_referrers[0].label | truncate: 24 }}</div>
    <div class="value value--large lg:value--xxlarge" data-value-fit="true">{{ top_referrers[0].nb_visits | number_with_delimiter: number_delim }}</div>
  {% elsif metrics contains 'top_countries' %}
    <div class="title lg:title--xlarge">Top country</div>
    <div class="label lg:label--large">{{ top_countries[0].label | truncate: 24 }}</div>
    <div class="value value--large lg:value--xxlarge" data-value-fit="true">{{ top_countries[0].nb_visits | number_with_delimiter: number_delim }}</div>
  {% endif %}

</div>

<div class="title_bar">
  <span class="title">Matomo</span>
  <span class="instance">{{ date_label }} · {{ site_label }}</span>
</div>
